{
  "$schema": "https://openclaw.ai/schemas/plugin.json",
  "id": "now4real",
  "name": "Now4real",
  "description": "Connect OpenClaw to Now4real pagechat via webhooks",
  "version": "1.0.0",
  "kind": "channel",
  "channels": ["now4real"],
  "configSchema": {
    "type": "object",
    "properties": {
      "now4real": {
        "type": "object",
        "properties": {
          "webhookAuthorization": {
            "type": "string",
            "description": "Webhook authorization secret for verification"
          }
        },
        "required": ["webhookAuthorization"]
      }
    }
  }
}
