{
  "$schema": "https://openclaw.ai/schemas/plugin.json",
  "id": "channel-now4real",
  "name": "Now4real",
  "description": "Connect OpenClaw to Now4real pagechat via webhooks",
  "version": "1.0.0",
  "kind": "channel",
  "channels": ["channel-now4real"],
  "configSchema": {
    "type": "object",
    "properties": {
      "channels": {
        "type": "object",
        "properties": {
          "channel-now4real": {
            "type": "object",
            "properties": {
              "apiKey": {
                "type": "string",
                "description": "Now4real API key"
              },
              "siteKey": {
                "type": "string",
                "description": "Now4real site key"
              },
              "webhookSecret": {
                "type": "string",
                "description": "Webhook signature secret for verification"
              }
            },
            "required": ["apiKey", "siteKey"]
          }
        }
      }
    }
  }
}
